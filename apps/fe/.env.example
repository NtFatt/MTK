# Optional FE overrides for local/dev.
# Leave all of these unset if you want Vite proxy + default room naming.

# Relative API base works best with the default Vite proxy.
VITE_API_BASE=

# Socket.IO
VITE_SOCKET_ORIGIN=
VITE_SOCKET_PATH=/socket.io

# Realtime tuning
VITE_RT_INVALIDATE_DEBOUNCE_MS=350
VITE_RT_JOIN_ACK_TIMEOUT_MS=350
VITE_RT_REPLAY_ACK_TIMEOUT_MS=900

# Internal room naming
VITE_RT_INTERNAL_BRANCH_ROOM_PREFIX=branch
VITE_RT_INTERNAL_OPS_ROOM_PREFIX=ops
VITE_RT_INTERNAL_INVENTORY_ROOM_PREFIX=inventory
