{
  "name": "hadilao-online",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "pnpm -r --parallel run --if-present dev",

    "build": "pnpm -r run --if-present build",
    "typecheck": "pnpm -r run --if-present typecheck",
    "lint": "pnpm -r run --if-present lint",
    "verify:static": "pnpm -C packages/contracts build && pnpm -C apps/fe lint && pnpm -C apps/fe typecheck && pnpm -C apps/fe build && pnpm -C apps/api typecheck && pnpm -C apps/api build",
    "verify:smokes": "pnpm -C apps/api verify:smokes",
    "verify:all": "pnpm verify:static && pnpm verify:smokes",

    "contracts:dev": "pnpm -C packages/contracts dev",
    "contracts:build": "pnpm -C packages/contracts build",

    "fe:dev": "pnpm -C apps/fe dev",
    "fe:build": "pnpm -C apps/fe build",
    "fe:preview": "pnpm -C apps/fe preview",

    "api:dev": "pnpm -C apps/api dev",
    "api:smoke": "pnpm -C apps/api smoke",
    "api:db:reset": "pnpm -C apps/api db:reset",
    "api:db:migrate": "pnpm -C apps/api db:migrate",
    "api:db:diff": "pnpm -C apps/api db:diff",

    "pr21:reset": "pnpm -C apps/api db:reset --yes && pnpm -C packages/contracts build",
    "pr21:verify:static": "pnpm verify:static",
    "pr21:verify:smokes": "pnpm verify:smokes",
    "pr21:verify:all": "pnpm verify:all"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.2.5"
    }
  }
}
